<p style="margin:0 0 12px;font-size:18px;font-weight:700;color:#047857;">{{greeting}}</p>
<p style="margin:0 0 16px;color:#4b5563;">{{intro}}</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:10px;margin-bottom:24px;">
  <tr><td style="padding:16px 18px;">
    <p style="margin:6px 0;"><strong>{{labelProduct}}:</strong> {{productTitle}}</p>
    <p style="margin:6px 0;"><strong>{{labelRating}}:</strong> {{rating}} / 5</p>
    <p style="margin:6px 0;"><strong>{{labelAuthor}}:</strong> {{authorName}}</p>
    {{#if comment}}
    <p style="margin:10px 0 0;font-style:italic;color:#6b7280;">« {{comment}} »</p>
    {{/if}}
  </td></tr>
</table>
<p style="text-align:center;margin:24px 0;">
  <a href="{{ctaUrl}}" style="display:inline-block;padding:12px 28px;background-color:#059669;color:#ffffff;text-decoration:none;border-radius:8px;font-weight:700;">{{ctaLabel}}</a>
</p>
