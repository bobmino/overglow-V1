{{!-- Shared email chrome — Overglow Trip --}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f3f4f6;margin:0;padding:24px 12px;">
  <tr>
    <td align="center">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e5e7eb;">
        <tr>
          <td style="background:linear-gradient(135deg,#059669 0%,#047857 100%);padding:28px 24px;text-align:center;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:800;color:#ffffff;letter-spacing:-0.3px;">Overglow Trip</p>
            <p style="margin:8px 0 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:rgba(255,255,255,0.9);">{{headerSubtitle}}</p>
          </td>
        </tr>
        <tr>
          <td style="padding:28px 24px;font-family:Arial,Helvetica,sans-serif;color:#374151;font-size:15px;line-height:1.6;">
            {{{body}}}
          </td>
        </tr>
        <tr>
          <td style="background:#f9fafb;padding:20px 24px;text-align:center;border-top:1px solid #e5e7eb;">
            <p style="margin:0 0 8px;font-family:Arial,Helvetica,sans-serif;font-size:13px;">
              <a href="{{frontendUrl}}" style="color:#059669;text-decoration:none;font-weight:600;">{{footerVisit}}</a>
              &nbsp;·&nbsp;
              <a href="{{frontendUrl}}/help" style="color:#6b7280;text-decoration:none;">{{footerHelp}}</a>
              &nbsp;·&nbsp;
              <a href="{{unsubscribeUrl}}" style="color:#6b7280;text-decoration:none;">{{footerUnsubscribe}}</a>
            </p>
            <p style="margin:0 0 6px;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#9ca3af;">
              <a href="https://www.instagram.com/" style="color:#9ca3af;text-decoration:none;">Instagram</a>
              &nbsp;·&nbsp;
              <a href="https://www.facebook.com/" style="color:#9ca3af;text-decoration:none;">Facebook</a>
            </p>
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#9ca3af;">
              © {{year}} Overglow Trip — Maroc<br/>
              {{companyAddress}}
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
