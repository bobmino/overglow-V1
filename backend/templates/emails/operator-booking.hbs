<p style="margin:0 0 12px;font-size:18px;font-weight:700;color:#047857;">{{greeting}}</p>
<p style="margin:0 0 20px;color:#4b5563;">{{intro}}</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;margin-bottom:24px;">
  <tr><td style="padding:16px 18px;">
    <p style="margin:0 0 10px;font-weight:700;color:#92400e;">{{detailsTitle}}</p>
    <p style="margin:6px 0;"><strong>{{labelClient}}:</strong> {{clientName}} ({{clientEmail}})</p>
    <p style="margin:6px 0;"><strong>{{labelProduct}}:</strong> {{productTitle}}</p>
    <p style="margin:6px 0;"><strong>{{labelDate}}:</strong> {{bookingDate}}</p>
    <p style="margin:6px 0;"><strong>{{labelTickets}}:</strong> {{tickets}}</p>
    <p style="margin:6px 0;"><strong>{{labelTotal}}:</strong> {{totalPrice}}</p>
    <p style="margin:6px 0;"><strong>{{labelRef}}:</strong> #{{bookingRef}}</p>
  </td></tr>
</table>
<p style="text-align:center;margin:24px 0;">
  <a href="{{ctaUrl}}" style="display:inline-block;padding:12px 28px;background-color:#059669;color:#ffffff;text-decoration:none;border-radius:8px;font-weight:700;">{{ctaLabel}}</a>
</p>
