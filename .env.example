# =============================================================================
# Overglow Trip — Environment variables template
# Copy to .env (backend root) and frontend/.env — never commit real secrets
# =============================================================================

# --- Core (required) ---
NODE_ENV=development
PORT=5001
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
MONGO_DB_NAME=overglow
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
FRONTEND_URL=http://localhost:5173
SITE_URL=https://www.overglow.online
# Production (canonical / sitemap / CORS) — VPS:
# FRONTEND_URL=https://www.overglow.online
# SITE_URL=https://www.overglow.online
# SEO_NOINDEX=true
# ALLOW_INDEXING=false
# Origines CORS supplémentaires (CSV), sans wildcard
# CORS_ALLOWED_ORIGINS=https://www.overglow.online,https://overglow.online

# --- Storage (souveraineté VPS — défaut local) ---
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
# Legacy optionnel (ne pas utiliser en prod) :
# STORAGE_DRIVER=cloudinary

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Frontend: VITE_STRIPE_PUBLIC_KEY=pk_test_...

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# --- CMI (Morocco) — required in production ---
CMI_STORE_KEY=
CMI_URL=https://payment.cmi.co.ma/payment/init

# --- Bank transfer (required in production — never hardcode) ---
BANK_IBAN=
BANK_SWIFT=
BANK_NAME=Attijariwafa Bank
BANK_ACCOUNT_NAME=Overglow Trip SARL

# --- Cloudinary (legacy only — prefer STORAGE_DRIVER=local) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (SMTP self-host / provider ; Resend optionnel) ---
# DNS SPF/DKIM/DMARC sur overglow.online = Wave 3 (voir playbook/09-MAIL-DNS.md)
RESEND_API_KEY=
RESEND_FROM=noreply@overglow.online
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Overglow Trip <noreply@overglow.online>
EMAIL_ENABLED=true

# --- AI chat (optional — never hardcode URL/keys) ---
AI_SERVICE_URL=
AI_API_KEY=
AI_MODEL=llama3.1
# If previous localtunnel URL/keys were committed, ROTATE them immediately.

# --- Cache (optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Webhooks / ops ---
IMPORT_WEBHOOK_API_KEY=
APPROVAL_REQUEST_DELAY_DAYS=3
SIMULATE_PAYMENT_FAILURE=0
# Payment simulator (dev only). NEVER enable in production — ignored + WARNING if set.
ENABLE_PAYMENT_SIM=false

# --- Admin bootstrap (scripts/createAdmin.js) ---
ADMIN_EMAIL=admin@overglow.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin Overglow

# =============================================================================
# Frontend (frontend/.env)
# =============================================================================
# VITE_API_URL=http://127.0.0.1:5001
# VITE_SITE_URL=https://www.overglow.online
# VITE_STRIPE_PUBLIC_KEY=pk_test_...
# VITE_ENABLE_PAYMENT_SIM=false
# VITE_SENTRY_DSN=
# VITE_GA4_MEASUREMENT_ID=
