# =============================================================================
# Overglow Trip — Environment variables template
# Copy to .env (backend root) and frontend/.env — never commit real secrets
# =============================================================================

# --- Core (required) ---
NODE_ENV=development
PORT=5001
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
MONGO_DB_NAME=overglow
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
FRONTEND_URL=http://localhost:5173
# Origines CORS supplémentaires (CSV), sans wildcard
# CORS_ALLOWED_ORIGINS=https://www.overglowtrip.com,https://staging.overglowtrip.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Frontend: VITE_STRIPE_PUBLIC_KEY=pk_test_...

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# --- CMI (Morocco) — required in production ---
CMI_STORE_KEY=
CMI_URL=https://payment.cmi.co.ma/payment/init

# --- Bank transfer (required in production — never hardcode) ---
BANK_IBAN=
BANK_SWIFT=
BANK_NAME=Attijariwafa Bank
BANK_ACCOUNT_NAME=Overglow Trip SARL

# --- Cloudinary (recommended in production) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (Resend preferred + optional SMTP) ---
RESEND_API_KEY=
RESEND_FROM=notifications@yourdomain.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_ENABLED=true

# --- Monitoring ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Cache (optional) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Webhooks / ops ---
IMPORT_WEBHOOK_API_KEY=
APPROVAL_REQUEST_DELAY_DAYS=3
SIMULATE_PAYMENT_FAILURE=0

# --- Admin bootstrap (scripts/createAdmin.js) ---
ADMIN_EMAIL=admin@overglow.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin Overglow

# =============================================================================
# Frontend (frontend/.env)
# =============================================================================
# VITE_API_URL=http://127.0.0.1:5001
# VITE_STRIPE_PUBLIC_KEY=pk_test_...
# VITE_SENTRY_DSN=
# VITE_GA4_MEASUREMENT_ID=
